# Google OAuth 2.0 Client ID (from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID for Web Application)
# Authorized JavaScript origins: http://localhost:3000, http://localhost:3001, https://saimanoj01.github.io
# Authorized redirect URIs: http://localhost:3000, http://localhost:3001, https://saimanoj01.github.io/expense/
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# (Optional) Google Gemini API Key for AI Auto-Classification (gemini-3.5-flash-lite)
# Get yours free at https://aistudio.google.com/apikey
# Users can also configure their key dynamically in AI Settings within the application interface.
VITE_GEMINI_API_KEY=your-gemini-api-key-here
